rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. 상담/안내: 누구나 작성(상담글 남기기) 가능하지만 조회 및 수정은 관리자만 가능하게 할 경우
    // 현재 코드 로직 상 사용자가 직접 조회하진 않으므로 쓰기 권한만 허용
    match /consultations/{docId} {
      allow read: if request.auth != null; // 관리자만 읽기
      allow create: if true;               // 누구나 쓰기 허용
      allow update, delete: if request.auth != null; // 관리자만 수정/삭제
    }
    
    // 2. 조리원 이용 후기: 누구나 읽고, 쓸 수 있으며 삭제도 비밀번호 확인 후 직접 하므로 허용
    match /postpartum_reviews/{docId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
      allow update: if request.auth != null;
    }
    
    // 3. 공지사항: 누구나 읽을 수 있고 관리자만 등록/수정/삭제
    match /notices/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 4. 팝업: 누구나 읽을 수 있고 관리자만 등록/수정/삭제
    match /popups/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 5. 그 외 모든 문서는 로그인한 관리자만 접근 가능 (보안 유지)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
