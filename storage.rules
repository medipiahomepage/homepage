rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 의료진 사진 폴더: 공개 읽기/쓰기 (업로드 후 제한 예정)
    match /doctors/{fileName} {
      allow read: if true;
      allow write: if true;
    }
    // 나머지 파일: 공개 읽기만 허용
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
